generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Consulta {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  telefono  String?
  destino   Destino
  mensaje   String
  estado    Estado   @default(nueva)
  creadoEn  DateTime @default(now())

  @@map("consultas")
}

enum Destino {
  cusco
  lima
  arequipa
}

enum Estado {
  nueva
  en_seguimiento
  cerrada
}
